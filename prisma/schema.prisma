// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model MUser {
  userId            String       @id @default(uuid())
  userName          String
  password          String
  userEmail         String       @unique
  // relationship
  subscriptionCode  String
  assoicatedChannel Channel?
  subscription      Subscription @relation(fields: [subscriptionCode], references: [subscriptionCode])
  // AUDIT
  createdAt         DateTime     @default(now())
  updatedAt         DateTime?    @updatedAt
}

model CurrentStatus {
  statusId         String     @id @default(uuid())
  mealStatus       MealStatus @default(NONE)
  updatedPerson    String?
  // relationships
  channelId        String     @unique
  relatedChannelId Channel    @relation(fields: [channelId], references: [channelId])
  // AUDIT
  createdAt        DateTime   @default(now())
  updatedAt        DateTime?  @updatedAt
}

model Channel {
  channelId        String         @id @default(uuid())
  channelName      String
  channelCode      String         @unique
  // relationships
  associatedStatus MealStatus?
  associatedSub    Subscription?
  channelFounder   String         @unique
  owner            MUser          @relation(fields: [channelFounder], references: [userId])
  // AUDIT
  createdAt        DateTime       @default(now())
  updatedAt        DateTime?      @updatedAt
  currentStatus    CurrentStatus?
}

model Subscription {
  subscriptionCode  String    @id @default(uuid())
  // relationships
  subscribers       MUser[]
  channelId         String    @unique
  associatedChannel Channel   @relation(fields: [channelId], references: [channelCode])
  // AUDIT
  createdAt         DateTime  @default(now())
  updatedAt         DateTime? @updatedAt
}

model Log {
  logId     String   @id @default(ulid())
  logString String
  logType   LogEnum
  // AUDIT
  createdAt DateTime @default(now())
}

// Enums
enum MealStatus {
  NONE
  STARTED
  PREPARING
  COOKING
  READY
}

enum LogEnum {
  AUTH
  USER
  MEALSTATUS
  CHANNEL
  SUBSCRIPTION
}
